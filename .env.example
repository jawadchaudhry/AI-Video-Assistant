# AI Video Assistant - Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API Key (get it from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenRouter model (defaults to Claude Sonnet)
# Options: anthropic/claude-sonnet-4-20250514, anthropic/claude-3-5-sonnet-20241022, google/gemini-2.0-flash-thinking-exp, etc.
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Whisper model (tiny, base, small, medium, large, large-v2, large-v3)
WHISPER_MODEL=base

# Optional: Embedding model for vector store
EMBEDDING_MODEL=all-MiniLM-L6-v2