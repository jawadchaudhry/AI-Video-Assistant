# Mistral AI API Key (Required)
# Get your free API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Whisper Model Configuration
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Embedding Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Storage Paths
# Use absolute paths on a VM, or keep defaults inside the container.
CACHE_DIR=cache
DOWNLOADS_DIR=downloads
HF_HOME=hf_cache

# Optional yt-dlp resilience tuning
YTDLP_SOURCE_ADDRESS=0.0.0.0
YTDLP_SLEEP_INTERVAL=1
YTDLP_MAX_SLEEP_INTERVAL=3

# RAG Configuration
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVER_K=6

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
